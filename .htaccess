Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 🔥 IGNORAR LA CARPETA ADMIN POR COMPLETO
    # Si la URL empieza por /admin, detener la reescritura aquí mismo
    RewriteRule ^admin/ - [L]

    # Si es un archivo o directorio que existe en el frontend, déjalo pasar
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Todo lo demás (rutas de tu SPA) se redirige al index.html
    RewriteRule ^(.*)$ /index.html [L] 
</IfModule>

DirectoryIndex index.html index.php
AddHandler application/x-httpd-php83 .php .php5 .php4 .php3