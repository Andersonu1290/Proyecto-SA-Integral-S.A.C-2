Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # 🔥 1. PROTEGER COCKPIT: Si la URL empieza por /admin, ignorar el resto de reglas
    RewriteCond %{REQUEST_URI} ^/admin [NC]
    RewriteRule ^ - [L]

    # 2. Archivos reales (CSS, JS, imágenes del frontend)
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # 3. Todo lo demás va al index.html de tu frontend
    RewriteRule ^(.*)$ /index.html [L] 
</IfModule>

DirectoryIndex index.html index.php
AddHandler application/x-httpd-php83 .php .php5 .php4 .php3